	</main>
</Layout>

<style>
	main {
		margin: auto;
		max-width: calc(100% - 2rem);
		line-height: 1.6;
	}
	
	section {
		width: 70%;
		margin: 0 auto;
		padding: 4em 0;
	}

	.services {
		width: 85%;
	}
	.services h2 {
		text-align: center;
	}
	.services-list {
		display: flex;
		justify-content: space-between;
		gap: 1em;
	}
	.services-list div {
		width: 400px;
	}

	.skills {
		display: flex;
		justify-content: space-evenly;
	}
	.skill-title {
		text-decoration: underline;
	}

	h4 {
		text-align: center;
	}
</style>
