---
interface Props {
    height: string;
    width: string;
    name: string;
}

const { height, width, name } = Astro.props;
---

<div>
    <img id="logo" src="/favicon-gradient.svg" alt="LM initials logo" {height} {width}>
    <h1>{name}</h1>
</div>


<style>
    div {
        display: flex;
        gap: 1em;
        align-items: center;
    }
</style>